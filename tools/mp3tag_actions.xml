<?xml version="1.0" encoding="UTF-8"?>
<!--
  Azioni Utente Mp3Tag per DoubleCMD
  ====================================
  Importa in DoubleCMD:
    Configurazione > Opzioni > Azioni utente > Importa > seleziona questo file

  REQUISITO: Python 3 installato e nel PATH di sistema.

  Prima di importare, modifica i percorsi sotto:
  sostituisci C:\DoubleCMD\plugins\tools\ con il percorso
  reale dove hai copiato la cartella "tools".
-->
<doublecmd>
  <actions>

    <action>
      <name>Mp3Tag\Modifica tag</name>
      <command>pythonw</command>
      <params>"C:\DoubleCMD\plugins\tools\mp3tag_edit.py" "%f"</params>
      <startpath>%D</startpath>
      <icon></icon>
      <shortcut>Ctrl+Alt+T</shortcut>
    </action>

    <action>
      <name>Mp3Tag\Batch tag editor</name>
      <command>pythonw</command>
      <params>"C:\DoubleCMD\plugins\tools\mp3tag_batch.py" %Lm</params>
      <startpath>%D</startpath>
      <icon></icon>
      <shortcut>Ctrl+Alt+B</shortcut>
    </action>

    <action>
      <name>Mp3Tag\Rinomina dai tag</name>
      <command>pythonw</command>
      <params>"C:\DoubleCMD\plugins\tools\mp3tag_rename.py" %Lm</params>
      <startpath>%D</startpath>
      <icon></icon>
      <shortcut>Ctrl+Alt+R</shortcut>
    </action>

  </actions>
</doublecmd>
